{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "orders-route": {
        "ClusterId": "orders-cluster", // This must match a cluster ID below
        "Match": { "Path": "/api/order/{**catch-all}" }
      },
      "worker-route": {
        "ClusterId": "worker-cluster", // This must match a cluster ID below
        "Match": { "Path": "/api/worker/{**catch-all}" }
      }
    },
    "Clusters": {
      "orders-cluster": { // Ensure this matches "orders-route.ClusterId"
        "Destinations": {
          "destination1": { "Address": "https://localhost:7013" }
        }
      },
      "worker-cluster": { // Ensure this matches "orders-route.ClusterId"
        "Destinations": {
          "destination1": { "Address": "https://localhost:7098" }
        }
      }
    }
  },
    "AllowedHosts": "*"
  }
